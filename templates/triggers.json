{
  "schemaVersion": 2,
  "defaultModel": "qwen2.5-coder-1.5b-uncensored",
  "defaultEndpoint": "http://127.0.0.1:8080/v1/chat/completions",
  "providers": {
    "local": {
      "url": "http://127.0.0.1:8080/v1/chat/completions",
      "model": "gemma-3n-e2b",
      "priority": 1,
      "maxTokens": 2048,
      "timeoutMs": 30000,
      "enabled": true,
      "role": "primary"
    },
    "anthropic": {
      "url": "https://api.anthropic.com/v1/messages",
      "model": "claude-haiku-4-5-20251001",
      "keyRef": "ANTHROPIC_KEY",
      "priority": 2,
      "enabled": true,
      "role": "finisher"
    },
    "openai": {
      "url": "https://api.openai.com/v1/chat/completions",
      "model": "gpt-4o-mini",
      "keyRef": "OPENAI_KEY",
      "priority": 3,
      "enabled": false,
      "role": "finisher"
    },
    "gemini_1": {
      "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent",
      "keyRef": "GEMINI_KEY_1",
      "priority": 4,
      "enabled": true,
      "role": "fallback"
    },
    "gemini_2": {
      "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent",
      "keyRef": "GEMINI_KEY_2",
      "priority": 5,
      "enabled": true,
      "role": "fallback"
    },
    "groq": {
      "url": "https://api.groq.com/openai/v1/chat/completions",
      "model": "gemma2-9b-it",
      "keyRef": "GROQ_KEY",
      "priority": 2,
      "maxTokens": 1024,
      "timeoutMs": 15000,
      "enabled": true,
      "role": "primary"
    },
    "cerebras": {
      "url": "https://api.cerebras.ai/v1/chat/completions",
      "model": "llama-3.3-70b",
      "keyRef": "CEREBRAS_KEY",
      "priority": 3,
      "maxTokens": 1024,
      "timeoutMs": 20000,
      "enabled": true,
      "role": "primary"
    },
    "anthropic": {
      "url": "https://api.anthropic.com/v1/messages",
      "model": "claude-haiku-4-5-20251001",
      "keyRef": "ANTHROPIC_KEY",
      "priority": 4,
      "enabled": true,
      "role": "finisher"
    },
    "openai": {
      "url": "https://api.openai.com/v1/chat/completions",
      "model": "gpt-4o-mini",
      "keyRef": "OPENAI_KEY",
      "priority": 5,
      "enabled": false,
      "role": "finisher"
    },
    "gemini_1": {
      "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent",
      "keyRef": "GEMINI_KEY_1",
      "priority": 6,
      "enabled": true,
      "role": "fallback"
    },
    "gemini_2": {
      "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent",
      "keyRef": "GEMINI_KEY_2",
      "priority": 7,
      "enabled": true,
      "role": "fallback"
    },
    "openrouter": {
      "url": "https://openrouter.ai/api/v1/chat/completions",
      "model": "meta-llama/llama-3.3-70b-instruct:free",
      "keyRef": "OPENROUTER_KEY",
      "priority": 8,
      "maxTokens": 1024,
      "timeoutMs": 30000,
      "enabled": false,
      "role": "fallback"
    },
    "deepseek": {
      "url": "https://api.deepseek.com/v1/chat/completions",
      "model": "deepseek-chat",
      "keyRef": "DEEPSEEK_KEY",
      "priority": 9,
      "enabled": false,
      "role": "primary"
    }
  },
  "routing": {
    "default": "local",
    "rules": [
      { "if": "trigger.pipeline == 'tot'", "use": "anthropic" },
      { "if": "trigger.maxTokens > 1024", "use": "anthropic" },
      { "if": "provider.local.unreachable", "use": "groq" },
      { "if": "provider.groq.rateLimited", "use": "cerebras" },
      { "if": "provider.cerebras.rateLimited", "use": "gemini_1" },
      { "if": "provider.gemini_1.rateLimited", "use": "gemini_2" },
      { "if": "trigger.budget == 'cheap'", "use": "groq" }
    ]
  },
  "context_layers_global": {
    "time": { "now": "{{system.time.iso}}", "tz": "{{system.tz}}" },
    "clipboard": { "text": "{{system.clipboard}}" },
    "selection": { "text": "{{system.selection}}" }
  },
  "triggers": {
    "/formal": {
      "pipeline": "cot",
      "system": "Rewrite the user's text in formal, professional tone. Preserve meaning exactly. Output only the rewritten text.",
      "temperature": 0.3,
      "max_tokens": 256
    },
    "/casual": {
      "pipeline": "cot",
      "system": "Rewrite the user's text in casual, friendly tone. Keep it natural. Output only the rewritten text.",
      "temperature": 0.5,
      "max_tokens": 256
    },
    "/code": {
      "pipeline": "cot",
      "system": "You are a code assistant. Convert the user's natural language description into clean, working code. Be concise.",
      "temperature": 0.1,
      "max_tokens": 512
    },
    "/expand": {
      "pipeline": "cot",
      "system": "Expand the user's brief notes into a full, well-written paragraph. Match their implied tone.",
      "temperature": 0.5,
      "max_tokens": 512
    },
    "/fix": {
      "pipeline": "cot",
      "system": "Fix grammar, spelling, and punctuation in the user's text. Preserve their voice and meaning. Output only the corrected text.",
      "temperature": 0.2,
      "max_tokens": 256
    },
    "<<cot>>": {
      "pipeline": "cot",
      "system": "Think step by step about the user's request.\nStep 1: Understand the intent\nStep 2: Identify key requirements\nStep 3: Draft response\nStep 4: Verify accuracy\n\nOutput your final answer after 'FINAL:'",
      "temperature": 0.4,
      "max_tokens": 512,
      "extract_pattern": "FINAL: (.*)"
    },
    "<<tot>>": {
      "pipeline": "tot",
      "system": "Generate 3 alternative approaches to the user's request.\n\nApproach A:\nApproach B:\nApproach C:\n\nEvaluate each on clarity, accuracy, and tone (1-5).\nSelect the best and output it after 'BEST:'",
      "temperature": 0.5,
      "max_tokens": 768,
      "extract_pattern": "BEST: (.*)",
      "branches": 3
    },
    "/meta": {
      "pipeline": "tot",
      "system": "You are a meta-skill builder. Given the user's task description, generate a new JSON skill config with: id, name, trigger, system prompt, pipeline (cot or tot), temperature, and max_tokens. Output valid JSON only.",
      "temperature": 0.7,
      "max_tokens": 1024
    },
    "/voice": {
      "pipeline": "cot",
      "provider": "local",
      "system_template": "{{user_input}}",
      "user_template": "",
      "temperature": 0.3,
      "max_tokens": 2048,
      "skill_routing": {
        "app": "md.obsidian",
        "skill": "vault_aware_draft",
        "description": "Voice transcript auto-routed to vault_aware_draft skill when in Obsidian"
      }
    }
  },
  "personas": {
    "professional": {
      "tone": "formal",
      "avoid": ["gonna", "wanna", "stuff", "basically"],
      "prefer": ["implement", "establish", "facilitate"],
      "contractions": false
    },
    "casual": {
      "tone": "conversational",
      "contractions": true,
      "sentence_length": "short"
    },
    "technical": {
      "tone": "precise",
      "vocabulary": "domain-specific",
      "contractions": false
    }
  },
  "appProfiles": {
    "md.obsidian": { "extends": "templates/obsidian.triggers.json" },
    "com.whatsapp": { "extends": "templates/whatsapp.triggers.json" },
    "com.google.android.gm": { "extends": "templates/gmail.triggers.json" },
    "*": { "basePersona": "professional" }
  },
  "skills": {}
}
